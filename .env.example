# Skopiuj ten plik jako .env i wpisz prawdziwe wartosci.
# .env jest w .gitignore - nigdy nie zostanie zacommitowany.

# Token od @BotFather na Telegramie (komenda /newbot)
TELEGRAM_BOT_TOKEN=

# Twoj chat_id - zostawiasz puste = wszyscy moga rozmawiac z botem.
# Wypelnij = whitelist (tylko wskazane id-ki maja dostep), oddziel przecinkami.
# Jak zdobyc: napisz /start do bota, potem otworz w przegladarce
# https://api.telegram.org/bot<TOKEN>/getUpdates i znajdz "chat":{"id":...
TELEGRAM_ALLOWED_CHAT_IDS=

# Sciezka do bazy SQLite (opcjonalne, domyslnie database.db)
TRAVEL_AGENT_DB=database.db
